{
  "manifest_version": 3,
  "key": "",
  "name": "InterfaceAI MVP",
  "version": "0.1.0",
  "description": "Chrome extension for InterfaceAI",
  "action": {
    "default_title": "InterfaceAI - Click to activate",
    "default_icon": "logo_128.png"
  },
  "icons": {
    "128": "logo_128.png"
  },
  "permissions": ["activeTab", "scripting", "tabs", "storage", "identity"],
  "oauth2": {
    "client_id": "YOUR_NEW_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": ["http://localhost:5050/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-overlay": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Toggle InterfaceAI overlay"
    },
    "open-settings": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "Open InterfaceAI settings"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["logo_128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
